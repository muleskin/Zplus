<Window x:Class="ZPlus.Client.Views.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Z+ — Home" Height="620" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="{Binding WelcomeText}" FontSize="22" FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: start / join -->
            <StackPanel Grid.Column="0">
                <Border Background="{StaticResource PanelBg}" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Start" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Start an instant meeting"
                                Command="{Binding StartInstantMeetingCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource PanelBg}" CornerRadius="10" Padding="20" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Join" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Meeting ID" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding JoinCode, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Password (if required)" Foreground="{StaticResource MutedFg}" Margin="0,10,0,4"/>
                        <TextBox Text="{Binding JoinPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Join meeting" Margin="0,14,0,0"
                                Command="{Binding JoinMeetingCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding Error}" Foreground="#FFFF7B7B" TextWrapping="Wrap" Margin="4,12,0,0"/>
                <TextBlock Text="{Binding Info}" Foreground="#FF7BE28B" TextWrapping="Wrap" Margin="4,4,0,0"/>
            </StackPanel>

            <!-- Right column: schedule + upcoming -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PanelBg}" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Schedule a meeting" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Topic" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ScheduleTopic, UpdateSourceTrigger=PropertyChanged}"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Date" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding ScheduleDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Time" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ScheduleTime, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Minutes" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ScheduleDuration, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Password (optional)" Foreground="{StaticResource MutedFg}" Margin="0,10,0,4"/>
                        <TextBox Text="{Binding SchedulePassword, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Schedule" Margin="0,14,0,0"
                                Command="{Binding ScheduleMeetingCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource PanelBg}" CornerRadius="10" Padding="20" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Your meetings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding MyMeetings}" Background="Transparent"
                                 BorderThickness="0" HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource TileBg}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Topic}" FontWeight="SemiBold"/>
                                                <TextBlock Foreground="{StaticResource MutedFg}" FontSize="12">
                                                    <Run Text="{Binding MeetingCode, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding ScheduledStartUtc, Mode=OneWay, StringFormat='{}{0:g}', TargetNullValue=Instant}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="Start"
                                                    Padding="12,5"
                                                    Command="{Binding DataContext.StartFromListCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
