<Application x:Class="ZPlus.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ZPlus.Client.Views"
             Startup="OnStartup">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBoolConverter x:Key="InverseBool"/>
        <views:InverseBoolToVisConverter x:Key="InverseBoolToVis"/>
        <views:NullToVisConverter x:Key="NullToVis"/>
        <views:NullToVisInverseConverter x:Key="NullToVisInverse"/>

        <!-- ZPlus dark theme palette -->
        <SolidColorBrush x:Key="WindowBg" Color="#FF1B1D22"/>
        <SolidColorBrush x:Key="PanelBg" Color="#FF24262E"/>
        <SolidColorBrush x:Key="TileBg" Color="#FF2C2F38"/>
        <SolidColorBrush x:Key="AccentBg" Color="#FF2D8CFF"/>
        <SolidColorBrush x:Key="AccentHoverBg" Color="#FF4B9DFF"/>
        <SolidColorBrush x:Key="DangerBg" Color="#FFE02F44"/>
        <SolidColorBrush x:Key="TextFg" Color="#FFF2F2F2"/>
        <SolidColorBrush x:Key="MutedFg" Color="#FF9AA0AA"/>
        <SolidColorBrush x:Key="FieldBg" Color="#FF15161A"/>
        <SolidColorBrush x:Key="FieldBorder" Color="#FF3A3D46"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextFg}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextFg}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource DangerBg}"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource TileBg}"/>
        </Style>
    </Application.Resources>
</Application>
