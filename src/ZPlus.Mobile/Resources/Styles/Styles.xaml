<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Page background -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource WindowBg}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Label" x:Key="Muted">
        <Setter Property="TextColor" Value="{StaticResource MutedFg}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Label" x:Key="Header">
        <Setter Property="TextColor" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextFg}" />
        <Setter Property="BackgroundColor" Value="{StaticResource FieldBg}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource MutedFg}" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource TextFg}" />
        <Setter Property="BackgroundColor" Value="{StaticResource FieldBg}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource MutedFg}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextFg}" />
        <Setter Property="BackgroundColor" Value="{StaticResource FieldBg}" />
        <Setter Property="TitleColor" Value="{StaticResource MutedFg}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource AccentBg}" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource TextFg}" />
        <Setter Property="BackgroundColor" Value="{StaticResource FieldBg}" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource AccentBg}" />
    </Style>

    <!-- Primary (accent) button is the default -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BackgroundColor" Value="{StaticResource AccentBg}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Button" x:Key="Ghost">
        <Setter Property="TextColor" Value="{StaticResource TextFg}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TileBg}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="Button" x:Key="Danger">
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BackgroundColor" Value="{StaticResource DangerBg}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>

</ResourceDictionary>
