<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZPlus.Client.ViewModels;assembly=ZPlus.Mobile"
             x:Class="ZPlus.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             Title="Sign in">
    <ScrollView>
        <VerticalStackLayout Padding="28,40" Spacing="12">
            <Label Text="Z+" FontSize="40" FontAttributes="Bold" TextColor="{StaticResource AccentBg}"
                   HorizontalOptions="Center" />
            <Label Text="Video meetings" Style="{StaticResource Muted}" HorizontalOptions="Center" Margin="0,0,0,16" />

            <Label Text="Server" Style="{StaticResource Muted}" />
            <Entry Text="{Binding ServerUrl}" Keyboard="Url" />

            <Label Text="Email" Style="{StaticResource Muted}" Margin="0,8,0,0" />
            <Entry Text="{Binding Email}" Keyboard="Email" />

            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsRegisterMode}">
                <Label Text="Display name" Style="{StaticResource Muted}" Margin="0,8,0,0" />
                <Entry Text="{Binding DisplayName}" />
            </VerticalStackLayout>

            <Label Text="Password" Style="{StaticResource Muted}" Margin="0,8,0,0" />
            <Entry Text="{Binding Password}" IsPassword="True" />

            <!-- MFA (shown only when required) -->
            <VerticalStackLayout Spacing="6" IsVisible="{Binding MfaRequired}">
                <Border BackgroundColor="{StaticResource TileBg}" StrokeThickness="0" Padding="12" Margin="0,10,0,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding MfaInfo}" Style="{StaticResource Muted}" />
                        <VerticalStackLayout Spacing="2" IsVisible="{Binding MfaSecret, Converter={StaticResource NotNull}}">
                            <Label Text="Setup key (type into your authenticator):" Style="{StaticResource Muted}" />
                            <Entry Text="{Binding MfaSecret}" IsReadOnly="True" FontFamily="Monospace" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
                <Label Text="Authentication code" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                <Entry Text="{Binding MfaCode}" Keyboard="Numeric" MaxLength="6" />
            </VerticalStackLayout>

            <Label Text="{Binding Error}" TextColor="#FFFF7B7B" IsVisible="{Binding Error, Converter={StaticResource NotNull}}" />

            <Button Text="{Binding SubmitLabel}" Command="{Binding SubmitCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" Margin="0,10,0,0" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Text="{Binding ToggleLabel}" Command="{Binding ToggleModeCommand}" Style="{StaticResource Ghost}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
