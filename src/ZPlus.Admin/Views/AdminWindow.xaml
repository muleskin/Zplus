<Window x:Class="ZPlus.Admin.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Z+ Admin" Height="680" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding HeaderText}" Foreground="{StaticResource MutedFg}" Margin="4,0,0,10"/>

        <TabControl Grid.Row="1" Background="{StaticResource PanelBg}" BorderThickness="0" Padding="10">
            <!-- ===================== USERS ===================== -->
            <TabItem Header="Users">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- New user form -->
                    <Border Grid.Row="0" Background="{StaticResource TileBg}" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Email" Foreground="{StaticResource MutedFg}" FontSize="11" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Display name" Foreground="{StaticResource MutedFg}" FontSize="11" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding NewDisplayName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Password" Foreground="{StaticResource MutedFg}" FontSize="11" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Role" Foreground="{StaticResource MutedFg}" FontSize="11" Margin="0,0,0,3"/>
                                <ComboBox ItemsSource="{Binding AvailableRoles}" SelectedItem="{Binding NewRole}"/>
                            </StackPanel>
                            <Button Grid.Column="8" Style="{StaticResource PrimaryButton}" Content="Add user"
                                    VerticalAlignment="Bottom" Command="{Binding CreateUserCommand}"/>
                            <Button Grid.Column="10" Style="{StaticResource GhostButton}" Content="Refresh"
                                    VerticalAlignment="Bottom" Command="{Binding RefreshUsersCommand}"/>
                        </Grid>
                    </Border>

                    <!-- User list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Users}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource TileBg}" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.2*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Email}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding CreatedAtUtc, StringFormat='Created {0:d}'}"
                                                           Foreground="{StaticResource MutedFg}" FontSize="11"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="2" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="4" VerticalAlignment="Center"
                                                      ItemsSource="{Binding DataContext.AvailableRoles, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding Role}"/>
                                            <TextBlock Grid.Column="6" Text="{Binding StatusLabel}" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                            <StackPanel Grid.Column="8" Orientation="Horizontal">
                                                <Button Style="{StaticResource PrimaryButton}" Content="Save" Padding="10,5" Margin="2,0"
                                                        Command="{Binding DataContext.SaveUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource GhostButton}" Content="{Binding DisableButtonLabel}" Padding="10,5" Margin="2,0"
                                                        Command="{Binding DataContext.ToggleDisabledCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource GhostButton}" Content="Reset password" Padding="10,5" Margin="2,0"
                                                        Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===================== SERVER SETTINGS ===================== -->
            <TabItem Header="Server settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Policies" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <CheckBox IsChecked="{Binding AllowSelfRegistration}" Foreground="{StaticResource TextFg}"
                                      Content="Allow users to register their own accounts" Margin="0,0,0,12"/>
                            <CheckBox IsChecked="{Binding RequireMeetingPasswords}" Foreground="{StaticResource TextFg}"
                                      Content="Require a password on every meeting" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Maximum participants per meeting:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding MaxParticipants, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            </StackPanel>
                            <TextBlock Text="Server listen URL (restart required to apply)"
                                       Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ListenUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <TextBlock Text="Public URL — the address users and invite links reach, e.g. http://192.168.1.10:5199"
                                       Foreground="{StaticResource MutedFg}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding PublicUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryButton}" Content="Save settings"
                                        Command="{Binding SaveSettingsCommand}"/>
                                <Button Style="{StaticResource GhostButton}" Content="Reload" Margin="8,0,0,0"
                                        Command="{Binding RefreshSettingsCommand}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email (meeting invitations)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Leave the SMTP host empty to disable email."
                                       Foreground="{StaticResource MutedFg}" Margin="0,0,0,10"/>
                            <TextBlock Text="SMTP host" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                <TextBlock Text="(587 uses STARTTLS)" Foreground="{StaticResource MutedFg}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="From address" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SmtpFrom, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="SMTP user (blank if no authentication)" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SmtpUser, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="SMTP password (blank = keep the saved one)" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SmtpPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ===================== ACTIVE MEETINGS ===================== -->
            <TabItem Header="Active meetings">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Style="{StaticResource GhostButton}" Content="Refresh" HorizontalAlignment="Left"
                            Margin="0,0,0,10" Command="{Binding RefreshMeetingsCommand}"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ActiveMeetings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource TileBg}" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Topic}" FontWeight="SemiBold"/>
                                                <TextBlock Foreground="{StaticResource MutedFg}" FontSize="12">
                                                    <Run Text="{Binding MeetingCode, Mode=OneWay}"/>
                                                    <Run Text=" · Host: "/>
                                                    <Run Text="{Binding HostDisplayName, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding ParticipantCount, Mode=OneWay}"/>
                                                    <Run Text=" participant(s)"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource DangerButton}" Content="End meeting"
                                                    Command="{Binding DataContext.ForceEndMeetingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" Text="{Binding Status}" Foreground="{StaticResource AccentBg}" Margin="4,8,0,0"/>
    </Grid>
</Window>
