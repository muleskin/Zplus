<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZPlus.ClientGui.Views.LoginWindow"
        Title="Z+ — Sign in" Width="420" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterScreen" Background="#FF1B1D22">
    <StackPanel Margin="36,28">
        <TextBlock Text="Z+" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center"
                   Foreground="#FF2D8CFF"/>
        <TextBlock Text="Video meetings — cross-platform client" HorizontalAlignment="Center"
                   Classes="muted" Margin="0,4,0,24"/>

        <TextBlock Text="Server" Classes="muted" Margin="0,0,0,4"/>
        <TextBox Text="{Binding ServerUrl}"/>

        <TextBlock Text="Email" Classes="muted" Margin="0,12,0,4"/>
        <TextBox Text="{Binding Email}"/>

        <StackPanel IsVisible="{Binding IsRegisterMode}">
            <TextBlock Text="Display name" Classes="muted" Margin="0,12,0,4"/>
            <TextBox Text="{Binding DisplayName}"/>
        </StackPanel>

        <TextBlock Text="Password" Classes="muted" Margin="0,12,0,4"/>
        <TextBox Text="{Binding Password}" PasswordChar="●"/>

        <!-- Two-factor authentication (shown only when required) -->
        <StackPanel IsVisible="{Binding MfaRequired}">
            <Border Background="#FF2C2F38" CornerRadius="6" Padding="10" Margin="0,14,0,0">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding MfaInfo}" TextWrapping="Wrap" Classes="muted" FontSize="12"/>
                    <StackPanel Spacing="2" IsVisible="{Binding MfaSecret, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="Setup key (type into your authenticator):" Classes="muted" FontSize="11"/>
                        <TextBox Text="{Binding MfaSecret, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <TextBlock Text="Authentication code" Classes="muted" Margin="0,10,0,4"/>
            <TextBox Text="{Binding MfaCode}" MaxLength="6"/>
        </StackPanel>

        <TextBlock Text="{Binding Error}" Foreground="#FFFF7B7B" TextWrapping="Wrap" Margin="0,12,0,0"/>

        <Button Classes="primary" Margin="0,16,0,0" Content="{Binding SubmitLabel}" IsDefault="True"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Command="{Binding SubmitCommand}"/>
        <Button Classes="ghost" Margin="0,10,0,0" Content="{Binding ToggleLabel}"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Command="{Binding ToggleModeCommand}"/>
    </StackPanel>
</Window>
