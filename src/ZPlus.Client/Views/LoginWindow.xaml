<Window x:Class="ZPlus.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Z+ — Sign in" Width="420"
        SizeToContent="Height" ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}">
    <Grid Margin="36,28">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Z+" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center"
                       Foreground="{StaticResource AccentBg}"/>
            <TextBlock Text="Video meetings for Windows" HorizontalAlignment="Center"
                       Foreground="{StaticResource MutedFg}" Margin="0,4,0,28"/>

            <TextBlock Text="Server" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Email" Foreground="{StaticResource MutedFg}" Margin="0,12,0,4"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Display name" Foreground="{StaticResource MutedFg}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <TextBlock Text="Password" Foreground="{StaticResource MutedFg}" Margin="0,12,0,4"/>
            <PasswordBox x:Name="PasswordInput" PasswordChanged="OnPasswordChanged"/>

            <TextBlock Text="{Binding Error}" Foreground="#FFFF7B7B" TextWrapping="Wrap" Margin="0,12,0,0"/>

            <Button Style="{StaticResource PrimaryButton}" Margin="0,16,0,0"
                    Content="{Binding SubmitLabel}" Command="{Binding SubmitCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    IsDefault="True"/>

            <Button Style="{StaticResource GhostButton}" Margin="0,10,0,0"
                    Content="{Binding ToggleLabel}" Command="{Binding ToggleModeCommand}"/>
        </StackPanel>
    </Grid>
</Window>
